# ============================================================
# LOCAL DEVELOPMENT (SQLite)
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./coderithm_events.db
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379/0

# ============================================================
# PYTHONANYWHERE (set these in PythonAnywhere Web tab)
# ============================================================
# DATABASE_URL=sqlite+aiosqlite:///./coderithm_events.db
# SECRET_KEY=your-random-secret-key-here
# DEBUG=False
# FRONTEND_URL=https://yourusername.pythonanywhere.com
# APP_URL=https://yourusername.pythonanywhere.com

# ============================================================
# OPTIONAL SERVICES
# ============================================================
# Cloudinary (for banner uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (for email notifications - free 100/day)
RESEND_API_KEY=

# OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
